# PostgreSQL
POSTGRES_DB=account_manager
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=3000
NODE_ENV=development

# Base de données (utilisé par TypeORM dans le backend)
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=account_manager
DATABASE_USER=postgres
DATABASE_PASSWORD=change_me_in_production

# Chiffrement AES-256-GCM (32 octets en base64)
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=change_me_generate_a_real_32_bytes_base64_key

# OAuth2
OAUTH_CLIENT_ID=app
OAUTH_CLIENT_SECRET=change_me_in_production
OAUTH_ACCESS_TOKEN_TTL=900
OAUTH_REFRESH_TOKEN_TTL=2592000

# Frontend
FRONTEND_PORT=4200
